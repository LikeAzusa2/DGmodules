root = true

[*.{java,gradle,properties,json,toml,md,yml,fsh,vsh}]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 4

[*.bat]
charset = utf-8
end_of_line = crlf
insert_final_newline = true

[*.json]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
